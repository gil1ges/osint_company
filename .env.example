OSINTCLI_TIMEOUT=15s
OSINTCLI_OUTPUT=./reports
OSINTCLI_USER_AGENT=osintcli/1.0
OSINTCLI_SHODAN_API_KEY=
OSINTCLI_SECURITYTRAILS_API_KEY=
