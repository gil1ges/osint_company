OSINTCLI_SPIDERFOOT_URL=http://127.0.0.1:5001
OSINTCLI_SPIDERFOOT_RESULTS_PATH=
OSINTCLI_MALTEGO_COMMAND=
OSINTCLI_MALTEGO_RESULTS_PATH=
